# Copy this file to .env and fill in your Supabase credentials
# Get them at: https://supabase.com -> Project Settings -> API

PORT=3000
ALLOWED_ORIGIN=http://localhost:5173

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here

# Voyage AI — get key at https://dash.voyageai.com
VOYAGE_API_KEY=your-voyage-key-here

# Anthropic Claude — get key at https://console.anthropic.com
ANTHROPIC_API_KEY=your-anthropic-key-here

# Premium Configuration
PREMIUM_PLAN_NAME=MindScrolling Inside
PREMIUM_BASE_PRICE_USD=4.99
PREMIUM_PRODUCT_ID_ANDROID=com.mindscrolling.inside
PREMIUM_PRODUCT_ID_IOS=com.mindscrolling.inside
