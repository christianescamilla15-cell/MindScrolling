# Copy this file to .env and fill in your Supabase credentials
# Get them at: https://supabase.com -> Project Settings -> API

PORT=3000
ALLOWED_ORIGIN=http://localhost:5173

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here

# Voyage AI — get key at https://dash.voyageai.com
VOYAGE_API_KEY=your-voyage-key-here

# Anthropic Claude — get key at https://console.anthropic.com
ANTHROPIC_API_KEY=your-anthropic-key-here

# Premium Configuration
PREMIUM_PLAN_NAME=MindScrolling Inside
PREMIUM_BASE_PRICE_USD=4.99
PREMIUM_PRODUCT_ID_ANDROID=com.mindscrolling.inside
PREMIUM_PRODUCT_ID_IOS=com.mindscrolling.inside

# Admin
ADMIN_SECRET=your-admin-secret-here

# Sentry error tracking — get DSN at sentry.io → Project → Client Keys
# Leave empty to disable (safe for local dev)
SENTRY_DSN=

# RevenueCat webhook — shared secret from RevenueCat dashboard → Project → Webhooks
# Leave empty in local dev; required in production
REVENUECAT_WEBHOOK_SECRET=
