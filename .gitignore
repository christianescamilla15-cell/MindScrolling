# =============================================================================
# MindScrolling — .gitignore
# Covers: Node.js · Flutter · Android · iOS · Supabase · VS Code · Windows
# =============================================================================

# ─── Secrets & Environment ───────────────────────────────────────────────────
.env
.env.local
.env.*.local
.env.development
.env.production
.env.test
*.secret
secrets/

# Keep examples tracked
!.env.example
!backend/.env.example
!flutter_app/.env.example

# ─── Node.js / Backend ───────────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-debug.log*
yarn.lock
.pnp.*
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
.yarn/install-state.gz

# Runtime
*.pid
*.seed
*.pid.lock
pids/
logs/
*.log

# Build & coverage
dist/
build/Release
coverage/
*.lcov
.nyc_output
lib-cov

# Cache
.npm
.eslintcache
.stylelintcache
.rpt2_cache/
.rts2_cache_cjs/
.rts2_cache_es/
.rts2_cache_umd/
.cache
.parcel-cache
.node_repl_history
*.tsbuildinfo

# ─── Flutter / Dart ───────────────────────────────────────────────────────────
flutter_app/.dart_tool/
flutter_app/.flutter-plugins
flutter_app/.flutter-plugins-dependencies
flutter_app/.packages
flutter_app/pubspec.lock
flutter_app/build/
flutter_app/.fvm/

# Generated Dart files
*.g.dart
*.freezed.dart
*.mocks.dart

# ─── Android ─────────────────────────────────────────────────────────────────
flutter_app/android/.gradle/
flutter_app/android/captures/
flutter_app/android/gradlew
flutter_app/android/gradlew.bat
flutter_app/android/local.properties
flutter_app/android/key.properties
flutter_app/android/**/*.keystore
flutter_app/android/**/*.jks
flutter_app/android/app/debug/
flutter_app/android/app/release/
flutter_app/android/app/profile/
flutter_app/android/app/google-services.json

# ─── iOS ─────────────────────────────────────────────────────────────────────
flutter_app/ios/Pods/
flutter_app/ios/.symlinks/
flutter_app/ios/Flutter/Flutter.framework
flutter_app/ios/Flutter/Flutter.podspec
flutter_app/ios/Flutter/App.framework
flutter_app/ios/Flutter/ephemeral/
flutter_app/ios/Runner.xcworkspace/xcuserdata/
flutter_app/ios/Runner.xcodeproj/xcuserdata/
flutter_app/ios/GoogleService-Info.plist
*.xcuserstate

# ─── Vite / Frontend (legacy) ────────────────────────────────────────────────
frontend/node_modules/
frontend/dist/
frontend/.vite/
frontend_legacy/node_modules/
frontend_legacy/dist/
frontend_legacy/.vite/

# ─── Supabase ────────────────────────────────────────────────────────────────
.supabase/
supabase/.branches/
supabase/.temp/

# ─── VS Code ─────────────────────────────────────────────────────────────────
.vscode/settings.json
.vscode/launch.json
.vscode/tasks.json
.vscode/*.code-snippets
.history/
*.vsix

# Keep shared VS Code extensions recommendation
!.vscode/extensions.json

# ─── OS & temp files ─────────────────────────────────────────────────────────
# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# Linux
*~

# ─── Editors ─────────────────────────────────────────────────────────────────
*.swp
*.swo
*.swn
*.bak
*.orig
*.tmp

# JetBrains / Android Studio
.idea/
*.iml
*.ipr
*.iws
.idea/workspace.xml
.idea/tasks.xml
.idea/gradle.xml
.idea/assetWizardSettings.xml
.idea/dictionaries/
.idea/libraries/
.idea/caches/

# ─── Tags / misc generated ───────────────────────────────────────────────────
tags_temp.json
*.tags
MindScroll-saved*.html
