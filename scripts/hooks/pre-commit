#!/bin/sh
# MindScrolling — pre-commit security hook
# Blocks commits that contain secrets, keys, or credentials.
# Runs on every `git commit`. Bypass only with: git commit --no-verify (emergency only).

RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
NC='\033[0m'

FAILED=0

echo "🔒 Security scan running..."

# ─── 1. Block .env files (real, not examples) ─────────────────────────────────
STAGED_ENV=$(git diff --cached --name-only | grep -E "^\.env$|/\.env$|\.env\.(local|development|production|test)$")
if [ -n "$STAGED_ENV" ]; then
  echo "${RED}BLOCKED: .env file staged for commit:${NC}"
  echo "$STAGED_ENV"
  FAILED=1
fi

# ─── 2. Scan for known secret patterns in staged files ────────────────────────
# Supabase service_role key (starts with eyJ, contains "service_role")
# Supabase anon key (starts with eyJ, contains "supabase")
# Generic API key patterns

STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E "\.(js|ts|dart|json|yaml|yml|sh|env|txt|md)$")

if [ -n "$STAGED_FILES" ]; then
  for FILE in $STAGED_FILES; do
    # Skip example files
    case "$FILE" in
      *.example|*example*|*EXAMPLE*) continue ;;
    esac

    CONTENT=$(git diff --cached -- "$FILE" | grep "^+" | grep -v "^+++")

    # Supabase JWT (anon or service_role)
    if echo "$CONTENT" | grep -qE "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9\.[A-Za-z0-9_-]+\.[A-Za-z0-9_-]+"; then
      echo "${RED}BLOCKED: Supabase JWT token found in: $FILE${NC}"
      FAILED=1
    fi

    # Supabase project URL (hardcoded, not from env)
    if echo "$CONTENT" | grep -qE '"https://[a-z]+\.supabase\.co"'; then
      echo "${RED}BLOCKED: Hardcoded Supabase URL found in: $FILE${NC}"
      FAILED=1
    fi

    # Anthropic API key
    if echo "$CONTENT" | grep -qE '"sk-ant-[A-Za-z0-9_-]+"'; then
      echo "${RED}BLOCKED: Anthropic API key found in: $FILE${NC}"
      FAILED=1
    fi

    # Voyage AI key
    if echo "$CONTENT" | grep -qE '"pa-[A-Za-z0-9_-]+"'; then
      echo "${RED}BLOCKED: Voyage AI API key found in: $FILE${NC}"
      FAILED=1
    fi

    # Generic long secrets (40+ char alphanumeric strings assigned to *key* or *secret* vars)
    if echo "$CONTENT" | grep -qiE "(api_key|secret|password|token|credential)\s*[:=]\s*['\"][A-Za-z0-9_/+=]{40,}['\"]"; then
      echo "${YELLOW}WARNING: Possible hardcoded secret in: $FILE${NC}"
      echo "  → Review the file before committing. Use \`git diff --cached $FILE\` to inspect."
      FAILED=1
    fi

    # Keystore / signing passwords in gradle files
    if echo "$CONTENT" | grep -qE "storePassword|keyPassword" && echo "$FILE" | grep -q "\.properties"; then
      echo "${RED}BLOCKED: Android signing credentials in: $FILE${NC}"
      FAILED=1
    fi
  done
fi

# ─── 3. Block Android keystore files ──────────────────────────────────────────
STAGED_KEYS=$(git diff --cached --name-only | grep -E "\.(keystore|jks|p12|pfx)$")
if [ -n "$STAGED_KEYS" ]; then
  echo "${RED}BLOCKED: Binary key/certificate file staged:${NC}"
  echo "$STAGED_KEYS"
  FAILED=1
fi

# ─── 4. Block google-services.json / GoogleService-Info.plist ─────────────────
STAGED_GS=$(git diff --cached --name-only | grep -E "google-services\.json|GoogleService-Info\.plist")
if [ -n "$STAGED_GS" ]; then
  echo "${RED}BLOCKED: Google services config staged (contains API keys):${NC}"
  echo "$STAGED_GS"
  FAILED=1
fi

# ─── Result ───────────────────────────────────────────────────────────────────
if [ "$FAILED" -eq 1 ]; then
  echo ""
  echo "${RED}Commit BLOCKED by security hook.${NC}"
  echo "Fix the issues above, then commit again."
  echo "If this is a false positive, use: git commit --no-verify  (use sparingly)"
  exit 1
fi

echo "${GREEN}Security scan passed.${NC}"
exit 0
